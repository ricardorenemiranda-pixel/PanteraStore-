---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Billetera" wide>
  <div id="state-loading" class="py-20 text-center text-neutral-400">Cargando...</div>

  <div id="state-content" class="hidden grid grid-cols-1 gap-6 lg:grid-cols-[320px_1fr]">
    <!-- Saldo + pedir retiro -->
    <section class="space-y-6">
      <div class="rounded-lg border border-dota-gold/40 bg-dota-gold/10 p-6 text-center">
        <p class="text-sm text-neutral-400">Saldo disponible</p>
        <p id="balance" class="mt-1 text-3xl font-bold text-dota-gold">S/ 0.00</p>
      </div>

      <div class="rounded-lg border border-dota-border bg-dota-panel p-4">
        <h2 class="mb-3 font-semibold text-neutral-100">Pedir retiro</h2>
        <form id="form-withdraw" class="space-y-3">
          <div>
            <label for="w-amount" class="mb-1 block text-sm text-neutral-300">Monto (S/)</label>
            <input
              id="w-amount"
              type="number"
              step="0.01"
              min="0.01"
              class="w-full rounded border border-dota-border bg-dota-bg px-3 py-2 text-sm text-neutral-200 focus:border-dota-gold/50 focus:outline-none"
            />
          </div>
          <div>
            <label for="w-method" class="mb-1 block text-sm text-neutral-300">Método</label>
            <select
              id="w-method"
              class="w-full rounded border border-dota-border bg-dota-bg px-3 py-2 text-sm text-neutral-200 focus:border-dota-gold/50 focus:outline-none"
            >
              <option value="Yape">Yape</option>
              <option value="Transferencia">Transferencia bancaria</option>
            </select>
          </div>
          <div>
            <label for="w-destination" class="mb-1 block text-sm text-neutral-300" id="w-destination-label">
              Número de Yape
            </label>
            <input
              id="w-destination"
              type="text"
              class="w-full rounded border border-dota-border bg-dota-bg px-3 py-2 text-sm text-neutral-200 focus:border-dota-gold/50 focus:outline-none"
            />
          </div>

          <p id="w-error" class="hidden text-sm text-dota-red"></p>
          <p id="w-success" class="hidden text-sm text-emerald-500">Retiro solicitado, quedó pendiente.</p>

          <button
            id="btn-withdraw"
            type="submit"
            class="w-full rounded-md bg-dota-red px-4 py-2 text-sm font-medium text-white transition hover:brightness-110 disabled:cursor-not-allowed disabled:opacity-50"
          >
            Solicitar retiro
          </button>
        </form>
      </div>
    </section>

    <!-- Historial -->
    <section class="space-y-6">
      <div class="rounded-lg border border-dota-border bg-dota-panel">
        <div class="border-b border-dota-border px-4 py-3">
          <h2 class="font-semibold text-neutral-100">Movimientos</h2>
        </div>
        <div id="transactions-list" class="divide-y divide-dota-border"></div>
        <p id="transactions-empty" class="hidden px-4 py-6 text-center text-sm text-neutral-500">
          Todavía no tienes movimientos.
        </p>
      </div>

      <div class="rounded-lg border border-dota-border bg-dota-panel">
        <div class="border-b border-dota-border px-4 py-3">
          <h2 class="font-semibold text-neutral-100">Retiros solicitados</h2>
        </div>
        <div id="withdrawals-list" class="divide-y divide-dota-border"></div>
        <p id="withdrawals-empty" class="hidden px-4 py-6 text-center text-sm text-neutral-500">
          Todavía no pediste ningún retiro.
        </p>
      </div>
    </section>
  </div>
</Layout>

<script>
  import { getMe, getWallet, requestWithdrawal, getMyWithdrawals, type WithdrawalDto } from "../lib/api";

  const soles = new Intl.NumberFormat("es-PE", { style: "currency", currency: "PEN" });
  const dateFmt = new Intl.DateTimeFormat("es-PE", { dateStyle: "medium", timeStyle: "short" });

  function show(id: string) {
    document.getElementById(id)?.classList.remove("hidden");
  }
  function hide(id: string) {
    document.getElementById(id)?.classList.add("hidden");
  }

  const TYPE_LABELS: Record<string, string> = {
    Sale: "Venta",
    Withdrawal: "Retiro",
    WithdrawalRefund: "Reembolso de retiro",
    Adjustment: "Ajuste",
  };

  const STATUS_LABELS: Record<string, { text: string; color: string }> = {
    Pending: { text: "Pendiente", color: "text-yellow-500" },
    Paid: { text: "Pagado", color: "text-emerald-500" },
    Rejected: { text: "Rechazado", color: "text-dota-red" },
  };

  async function refreshWallet() {
    const wallet = await getWallet();
    const balanceEl = document.getElementById("balance");
    const listEl = document.getElementById("transactions-list");
    if (!wallet || !balanceEl || !listEl) return;

    balanceEl.textContent = soles.format(wallet.balance);
    listEl.innerHTML = "";

    document.getElementById("transactions-empty")?.classList.toggle("hidden", wallet.transactions.length > 0);

    for (const t of wallet.transactions) {
      const row = document.createElement("div");
      row.className = "flex items-center justify-between px-4 py-3 text-sm";

      const left = document.createElement("div");
      const label = document.createElement("p");
      label.className = "text-neutral-200";
      label.textContent = t.description || TYPE_LABELS[t.type] || t.type;
      const date = document.createElement("p");
      date.className = "text-xs text-neutral-500";
      date.textContent = dateFmt.format(new Date(t.createdAtUtc));
      left.appendChild(label);
      left.appendChild(date);

      const amount = document.createElement("span");
      amount.className = `font-semibold ${t.amount >= 0 ? "text-emerald-500" : "text-dota-red"}`;
      amount.textContent = `${t.amount >= 0 ? "+" : ""}${soles.format(t.amount)}`;

      row.appendChild(left);
      row.appendChild(amount);
      listEl.appendChild(row);
    }
  }

  async function refreshWithdrawals() {
    const withdrawals = await getMyWithdrawals();
    const listEl = document.getElementById("withdrawals-list");
    if (!listEl) return;

    listEl.innerHTML = "";
    document.getElementById("withdrawals-empty")?.classList.toggle("hidden", withdrawals.length > 0);

    for (const w of withdrawals as WithdrawalDto[]) {
      const row = document.createElement("div");
      row.className = "flex items-center justify-between px-4 py-3 text-sm";

      const left = document.createElement("div");
      const label = document.createElement("p");
      label.className = "text-neutral-200";
      label.textContent = `${w.method} · ${w.destination}`;
      const date = document.createElement("p");
      date.className = "text-xs text-neutral-500";
      date.textContent = dateFmt.format(new Date(w.createdAtUtc));
      left.appendChild(label);
      left.appendChild(date);

      const right = document.createElement("div");
      right.className = "text-right";
      const amount = document.createElement("p");
      amount.className = "font-semibold text-neutral-200";
      amount.textContent = soles.format(w.amount);
      const status = document.createElement("p");
      const info = STATUS_LABELS[w.status] ?? { text: w.status, color: "text-neutral-400" };
      status.className = `text-xs ${info.color}`;
      status.textContent = info.text;
      right.appendChild(amount);
      right.appendChild(status);

      row.appendChild(left);
      row.appendChild(right);
      listEl.appendChild(row);
    }
  }

  async function main() {
    const me = await getMe();
    if (!me.authenticated) {
      window.location.href = "/";
      return;
    }

    await Promise.all([refreshWallet(), refreshWithdrawals()]);

    const methodSelect = document.getElementById("w-method") as HTMLSelectElement | null;
    const destinationLabel = document.getElementById("w-destination-label");
    methodSelect?.addEventListener("change", () => {
      if (destinationLabel) {
        destinationLabel.textContent = methodSelect.value === "Yape" ? "Número de Yape" : "Número de cuenta / CCI";
      }
    });

    const form = document.getElementById("form-withdraw") as HTMLFormElement | null;
    const btn = document.getElementById("btn-withdraw") as HTMLButtonElement | null;

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      hide("w-error");
      hide("w-success");

      const amountInput = document.getElementById("w-amount") as HTMLInputElement | null;
      const destinationInput = document.getElementById("w-destination") as HTMLInputElement | null;
      const amount = parseFloat(amountInput?.value ?? "0");
      const method = methodSelect?.value ?? "Yape";
      const destination = destinationInput?.value.trim() ?? "";

      if (btn) {
        btn.disabled = true;
        btn.textContent = "Enviando...";
      }

      const { error } = await requestWithdrawal(amount, method, destination);

      if (btn) {
        btn.disabled = false;
        btn.textContent = "Solicitar retiro";
      }

      if (error) {
        const errorEl = document.getElementById("w-error");
        if (errorEl) {
          errorEl.textContent = error;
          show("w-error");
        }
        return;
      }

      show("w-success");
      if (amountInput) amountInput.value = "";
      if (destinationInput) destinationInput.value = "";
      await Promise.all([refreshWallet(), refreshWithdrawals()]);
    });

    hide("state-loading");
    show("state-content");
  }

  main();
</script>
